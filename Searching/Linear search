#include<iostream>
using namespace std;

int main()
{
    int a[100], n, i, key, found = 0;

    cout<<"Enter size: ";
    cin>>n;

    cout<<"Enter elements: ";
    for(i=0;i<n;i++)
        cin>>a[i];

    cout<<"Enter number to search: ";
    cin>>key;

    for(i=0;i<n;i++)
    {
        if(a[i] == key)
        {
            cout<<"Found at position "<<i+1;
            found = 1;
            break;
        }
    }

    if(found == 0)
        cout<<"Not Found";

    return 0;
}
