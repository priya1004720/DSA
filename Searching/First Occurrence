#include<iostream>
using namespace std;

int main()
{
    int a[100], n, i, key, pos = -1;

    cin>>n;
    for(i=0;i<n;i++)
        cin>>a[i];

    cin>>key;

    for(i=0;i<n;i++)
    {
        if(a[i] == key)
        {
            pos = i;
            break;
        }
    }

    if(pos != -1)
        cout<<"First occurrence at "<<pos+1;
    else
        cout<<"Not Found";

    return 0;
}
